# llama.cpp Model Configuration File
# Equivalent to Ollama Modelfile for T-002.4 and T-002.5
# Hardware-optimized for Intel i5-9500 (6 cores, no hyperthreading)

# Base Model Configuration
FROM ./Tools/models/small-elite/llama-3.2-1b-instruct-q4_k_m.gguf

# Hardware-Specific Parameters (i5-9500 optimized)
PARAMETER num_thread 6                    # 6 physical cores, no hyperthreading
PARAMETER num_ctx 2048                    # Context window size
PARAMETER num_batch 512                   # Batch size for processing
PARAMETER num_predict 2048                # Maximum tokens to generate
PARAMETER temperature 0.7                 # Creativity vs determinism
PARAMETER top_p 0.9                       # Nucleus sampling
PARAMETER repeat_penalty 1.1             # Reduce repetition
PARAMETER presence_penalty 0.0            # Encourage new topics
PARAMETER frequency_penalty 0.0           # Reduce word frequency

# Memory and Performance Optimization
PARAMETER use_mmap true                   # Memory map for faster loading
PARAMETER use_mlock false                  # Don't lock memory (CPU-only)
PARAMETER n_gpu_layers -1                 # -1 = use all available GPU layers (0 for CPU)
PARAMETER type_k q8_0                     # KV cache quantization
PARAMETER type_v q8_0                     # Value cache quantization
PARAMETER rope_scaling_type 1             # Position encoding scaling
PARAMETER rope_freq_base 10000            # RoPE frequency base
PARAMETER rope_freq_scale 1.0            # RoPE frequency scale

# System Prompt for Technical Assistant
SYSTEM You are a helpful AI assistant optimized for CPU inference on an Intel i5-9500. You provide accurate, concise responses and excel at technical tasks including coding, analysis, and problem-solving. You prioritize clarity and correctness in your responses.

# Model Variants Configuration
TEMPLATE llama32-optimized:
    FROM ./Tools/models/small-elite/llama-3.2-1b-instruct-q4_k_m.gguf
    PARAMETER num_thread 6
    PARAMETER num_ctx 2048
    PARAMETER temperature 0.7
    SYSTEM You are Llama 3.2 optimized for i5-9500 CPU inference.

TEMPLATE qwen-reasoning:
    FROM ./Tools/models/small-elite/qwen2.5-1.5b-instruct-q4_k_m.gguf
    PARAMETER num_thread 6
    PARAMETER num_ctx 2048
    PARAMETER temperature 0.6
    SYSTEM You are Qwen2.5, optimized for reasoning and complex problem-solving on CPU.

TEMPLATE coding-specialist:
    FROM ./Tools/models/small-elite/qwen2.5-coder-1.5b-instruct-q4_k_m.gguf
    PARAMETER num_thread 6
    PARAMETER num_ctx 4096
    PARAMETER temperature 0.3
    SYSTEM You are a coding specialist optimized for generating and debugging code on CPU-based systems.

TEMPLATE efficiency-focused:
    FROM ./Tools/models/small-elite/smolLM2-1.7b-instruct-q4_k_m.gguf
    PARAMETER num_thread 6
    PARAMETER num_ctx 2048
    PARAMETER temperature 0.7
    SYSTEM You are SmolLM2, optimized for efficient inference and resource-constrained environments.

TEMPLATE ultra-lightweight:
    FROM ./Tools/models/ultra-lightweight/tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf
    PARAMETER num_thread 6
    PARAMETER num_ctx 1024
    PARAMETER temperature 0.8
    SYSTEM You are TinyLlama, optimized for maximum speed and minimal resource usage.

# Performance Notes for i5-9500:
# - num_thread set to 6 (physical cores) - no hyperthreading benefit
# - temperature 0.7 balances creativity and reliability
# - q8_0 KV cache provides good memory/quality trade-off for CPU
# - Context size 2048 is optimal for available memory bandwidth
# - Batch size 512 matches CPU cache capabilities

# Usage Examples:
# llama-cli -m ./Tools/models/small-elite/llama-3.2-1b-instruct-q4_k_m.gguf --file modelfile.llamacpp
# llama-server -m ./Tools/models/small-elite/llama-3.2-1b-instruct-q4_k_m.gguf --ctx-size 2048 -t 6
